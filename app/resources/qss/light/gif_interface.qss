/* ====== Base ====== */
#view {
    background-color: transparent;
}

QScrollArea {
    border: none;
    background-color: transparent;
}


/* ====== Section Widget ====== */
#sectionWidget {
    background-color: rgba(0, 0, 0, 0.024);
    border-radius: 12px;
}

#viewTitleLabel {
    color: black;
    font: 20px "Segoe UI SemiBold", "Microsoft YaHei", 'PingFang SC';
    font-weight: 700;
}


/* ====== Drop Zone ====== */
GifDropZone {
    border: 2px dashed rgba(0, 0, 0, 0.15);
    border-radius: 12px;
    background-color: rgba(0, 0, 0, 0.024);
}
GifDropZone:hover {
    border-color: var(--ThemeColorPrimary);
    background-color: rgba(0, 0, 0, 0.04);
}
GifDropZone[dragHover="true"] {
    border-color: var(--ThemeColorPrimary);
    background-color: rgba(0, 161, 236, 0.10);
}

GifDropZone > #hintLabel {
    font-size: 14px;
    color: black;
    background-color: transparent;
}
GifDropZone > #subHintLabel {
    font-size: 12px;
    color: rgb(95, 95, 95);
    background-color: transparent;
}


/* ====== Import Cards (GifCard) ====== */
GifCard {
    background-color: rgba(0, 0, 0, 0.024);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 8px;
}
GifCard:hover {
    background-color: rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.10);
}
#thumbLabel {
    background-color: rgba(0, 0, 0, 0.03);
    border-radius: 4px;
}
GifCard > BodyLabel {
    color: black;
}


/* ====== Result Cards ====== */
CompressResultCard,
ExtractResultCard {
    background-color: rgba(0, 0, 0, 0.024);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 8px;
}
CompressResultCard:hover,
ExtractResultCard:hover {
    background-color: rgba(0, 0, 0, 0.06);
    border-color: rgba(0, 0, 0, 0.10);
}
#resultThumb {
    background-color: rgba(0, 0, 0, 0.03);
    border-radius: 4px;
}
CompressResultCard > BodyLabel,
ExtractResultCard > BodyLabel {
    color: black;
}


/* ====== Output Directory Label ====== */
#outputDirLabel {
    padding: 6px 12px;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 6px;
    background-color: rgba(0, 0, 0, 0.024);
    color: black;
}
